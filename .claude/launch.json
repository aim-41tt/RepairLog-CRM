{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "RepairLog Frontend (ng serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ng", "serve"],
      "port": 4200,
      "autoPort": true,
      "cwd": "RepairLog-frontend"
    },
    {
      "name": "RepairLog Backend (Spring Boot)",
      "runtimeExecutable": "mvn",
      "runtimeArgs": ["spring-boot:run"],
      "port": 8080,
      "cwd": "RepairLog-backend"
    }
  ]
}
